# Required
project_id       = "my-gcp-project-id"
massive_api_key  = "your-massive-api-key"
anthropic_api_key = "sk-ant-..."

# Optional
google_api_key   = ""                    # For Gemini market context feature
region           = "us-east4"            # Low latency to US markets
zone             = "us-east4-c"
machine_type     = "e2-medium"           # 2 vCPU, 4GB RAM (~$24/mo)
data_disk_size   = 30                    # GB, for DuckDB + flat files
ssh_pub_key_path = "~/.ssh/id_ed25519.pub"
app_repo_url     = "https://github.com/aikalima/decay_core.git"
domain_name      = ""                    # Set for HTTPS via certbot (e.g. "decay.example.com")
